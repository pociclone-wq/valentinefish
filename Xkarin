local function Tab(name)
    local t = Instance.new("TextButton", Sidebar)
    t.Size = UDim2.new(1, 0, 0, 28)
    t.BackgroundTransparency = 1
    t.Text = "    " .. name
    t.TextColor3 = (name == "Home") and NeonBlue or Color3.fromRGB(150, 150, 150)
    t.Font = Enum.Font.Gotham
    t.TextSize = 11
    t.TextXAlignment = Enum.TextXAlignment.Left
    
    local Ind = Instance.new("Frame", t)
    Ind.Size = UDim2.new(0, 2, 1, 0)
    Ind.BackgroundColor3 = NeonBlue
    Ind.BorderSizePixel = 0
    Ind.Visible = (name == "Home")

    local p = Instance.new("Frame", Main)
    p.Name = name
    p.Position = UDim2.new(0, 110, 0, 40)
    p.Size = UDim2.new(1, -120, 1, -50)
    p.BackgroundTransparency = 1
    p.Visible = (name == "Home")
    AllPages[name] = p

    t.MouseButton1Click:Connect(function() 
        for k, v in pairs(AllPages) do v.Visible = (k == name) end
        for _, child in pairs(Sidebar:GetChildren()) do
            if child:IsA("TextButton") then 
                child.TextColor3 = Color3.fromRGB(150,150,150)
                if child:FindFirstChild("Frame") then child.Frame.Visible = false end
            end
        end
        t.TextColor3 = NeonBlue
        Ind.Visible = true
    end)
    return p
end

