Instance.new("UICorner", LocList).CornerRadius = UDim.new(0, 5)
local UIListLayoutL = Instance.new("UIListLayout", LocList)

local function Btn(txt, y)
    local b = Instance.new("TextButton", Tele)
    b.Text = txt
    b.Position = UDim2.new(0.5, -110, 0, y)
    b.Size = UDim2.new(0, 220, 0, 28)
    b.BackgroundColor3 = NeonBlue
    b.TextColor3 = Color3.new(0,0,0)
    b.Font = Enum.Font.GothamBold
    b.TextSize = 11
    Instance.new("UICorner", b).CornerRadius = UDim.new(0, 4)
    return b
end

local TPBtn = Btn("Teleport Now", 115)
local RefBtn = Btn("Refresh Player List", 150)

local function refreshPlayers()
	for _, child in pairs(PlayerList:GetChildren()) do if child:IsA("TextButton") then child:Destroy() end end
	local count = 0
	for _, player in pairs(Players:GetPlayers()) do
		if player ~= LocalPlayer then
			count += 1
			local b = Instance.new("TextButton", PlayerList)
			b.Size = UDim2.new(1, 0, 0, 25)
			b.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
			b.Text = player.Name
			b.TextColor3 = Color3.new(1,1,1)
			b.Font = Enum.Font.Gotham
			b.TextSize = 10
			b.ZIndex = 11
			Instance.new("UICorner", b).CornerRadius = UDim.new(0, 4)
			b.MouseButton1Click:Connect(function()
				SelectedPlayer = player
                SelectedLoc = nil
				PlayerList.Visible = false
				DropBtn.Text = " "..player.Name .. " ▼"
                DropBtnL.Text = " Select Location ▼"
			end)
		end
	end
	PlayerList.CanvasSize = UDim2.new(0, 0, 0, count * 27)
end

local function loadLocations()
    local success, LocData = pcall(function()
        return loadstring(game:HttpGet("https://raw.githubusercontent.com/pociclone-wq/valentinefish/refs/heads/main/locations.lua"))()
    end)
    if success then
        for _, child in pairs(LocList:GetChildren()) do if child:IsA("TextButton") then child:Destroy() end end
        local sortedNames = {}
        for name in pairs(LocData) do table.insert(sortedNames, name) end
        table.sort(sortedNames)
        for _, name in pairs(sortedNames) do
            local b = Instance.new("TextButton", LocList)
            b.Size = UDim2.new(1, 0, 0, 25)
            b.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
            b.Text = name
            b.TextColor3 = Color3.new(1,1,1)
            b.Font = Enum.Font.Gotham
            b.TextSize = 10
            b.ZIndex = 16
            Instance.new("UICorner", b).CornerRadius = UDim.new(0, 4)
            b.MouseButton1Click:Connect(function()
                SelectedLoc = LocData[name]
                SelectedPlayer = nil
                LocList.Visible = false
                DropBtnL.Text = " "..name.." ▼"
                DropBtn.Text = " Select Player ▼"
            end)
        end
        LocList.CanvasSize = UDim2.new(0, 0, 0, #sortedNames * 27)
    end
end

DropBtn.MouseButton1Click:Connect(function() PlayerList.Visible = not PlayerList.Visible LocList.Visible = false end)
DropBtnL.MouseButton1Click:Connect(function() LocList.Visible = not LocList.Visible PlayerList.Visible = false end)

TPBtn.MouseButton1Click:Connect(function()
	if SelectedPlayer and SelectedPlayer.Character then
		LocalPlayer.Character.HumanoidRootPart.CFrame = SelectedPlayer.Character.HumanoidRootPart.CFrame * CFrame.new(0,0,-3)
    elseif SelectedLoc then
        LocalPlayer.Character.HumanoidRootPart.CFrame = SelectedLoc
	end
end)

RefBtn.MouseButton1Click:Connect(function() refreshPlayers() loadLocations() end)
Players.PlayerAdded:Connect(refreshPlayers)
Players.PlayerRemoving:Connect(refreshPlayers)

-- Toggle Logic
Icon.MouseButton1Click:Connect(function() Main.Visible = not Main.Visible end)
Hide.MouseButton1Click:Connect(function() Main.Visible = false end)
Close.MouseButton1Click:Connect(function() ScreenGui:Destroy() end)

refreshPlayers()
loadLocations()
