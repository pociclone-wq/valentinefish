local function sendWebhook(fullText, category, url)
    if not url or url == "" then return end
    local req = (syn and syn.request) or (http and http.request) or http_request or (fluxus and fluxus.request) or request
    if not req then return end

    local cleanerText = fullText:gsub("<[^>]*>", "") 
    local luckyPlayer = cleanerText:match("%[Server%]%: (.-) obtained") or "Unknown Player"
    
    local displayCategory = "Mythic"
    if category == "secret" then displayCategory = "Secret" end
    if category == "ruby" or category == "evo" then displayCategory = "Stone" end
    
    local s = os.time() - startTime
    local runtime = string.format("%02d:%02d:%02d", math.floor(s/3600), math.floor((s%3600)/60), s%60)
    local color = (category == "secret" and 65280) or 16711680

    pcall(function()
        req({
            Url = url, Method = "POST", Headers = {["Content-Type"] = "application/json"},
            Body = game:GetService("HttpService"):JSONEncode({
                ["content"] = "Congratulations!! **" .. luckyPlayer .. "** You have obtained a new **" .. displayCategory .. "** fish!",
                ["embeds"] = {{
                    ["description"] = "Berhasil Menangkap: **" .. cleanerText .. "**\n\n**Script Runtime:** " .. runtime .. "\n| Ruby: " .. count.ruby .. " |  Evo: " .. count.evo .. " |  Mythic: " .. count.mythic .. " |  Secret: " .. count.secret,
                    ["color"] = color, ["footer"] = {["text"] = "Server Mybubub • " .. os.date("%X")}
                }}
            })
        })
    end)
end

game:GetService("TextChatService").OnIncomingMessage = function(message)
    local txt = message.Text:lower()
    if txt:find("%[server%]:") and txt:find("obtained") then
        local cat = nil
        for _, n in pairs(list_ruby) do if txt:find(n:lower()) then cat = "ruby" break end end
        if not cat then for _, n in pairs(list_evo) do if txt:find(n:lower()) then cat = "evo" break end end end
        if not cat then for _, n in pairs(list_mythic) do if txt:find(n:lower()) then cat = "mythic" break end end end
        if not cat then for _, n in pairs(list_secret) do if txt:find(n:lower()) then cat = "secret" break end end end
        
        if cat then
            count[cat] = count[cat] + 1
            local isMine = txt:find(LocalPlayer.Name:lower())
            if WebFlags.GlobalDefault then sendWebhook(message.Text, cat, webhook_default) end
            if WebFlags.SelfDefault and isMine then sendWebhook(message.Text, cat, webhook_default) end
            local customUrl = WebInput.Text
            if customUrl ~= "" then
                if WebFlags.GlobalCustom then sendWebhook(message.Text, cat, customUrl) end
                if WebFlags.SelfCustom and isMine then sendWebhook(message.Text, cat, customUrl) end
            end
        end
    end
end

